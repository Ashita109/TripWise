# TripWise Backend — Environment Variables
# Copy this file to .env and fill in your values

# JWT secret key (change this to a random string in production)
SECRET_KEY=tripwise-change-this-secret-key

# Google Gemini API key — get yours free at https://aistudio.google.com/
# Leave blank to use the built-in demo itinerary
GEMINI_API_KEY=
